# ══════════════════════════════════════════════════════════════════════════════
# Application
# ══════════════════════════════════════════════════════════════════════════════
APP_ENV=development                   # development | staging | production
APP_NAME=google-rag-agent
APP_VERSION=0.1.0
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
DEBUG=true

# ══════════════════════════════════════════════════════════════════════════════
# Server
# ══════════════════════════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8080
WORKERS=1                             # Increase for production

# ══════════════════════════════════════════════════════════════════════════════
# Google Cloud / Vertex AI
# ══════════════════════════════════════════════════════════════════════════════
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ══════════════════════════════════════════════════════════════════════════════
# Gemini / Vertex AI Models
# ══════════════════════════════════════════════════════════════════════════════
VERTEX_LLM_MODEL=gemini-1.5-pro
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_LLM_TEMPERATURE=0.2
VERTEX_LLM_MAX_TOKENS=8192

# ══════════════════════════════════════════════════════════════════════════════
# Google Drive
# ══════════════════════════════════════════════════════════════════════════════
GDRIVE_CREDENTIALS_FILE=credentials/gdrive_oauth_credentials.json
GDRIVE_TOKEN_FILE=credentials/gdrive_token.json
GDRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly
GDRIVE_ROOT_FOLDER_ID=                # Optional: restrict ingestion to folder

# ══════════════════════════════════════════════════════════════════════════════
# ChromaDB
# ══════════════════════════════════════════════════════════════════════════════
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=gdrive_documents
CHROMA_HOST=                          # Set for remote ChromaDB server
CHROMA_PORT=8000

# ══════════════════════════════════════════════════════════════════════════════
# RAG Configuration
# ══════════════════════════════════════════════════════════════════════════════
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# ══════════════════════════════════════════════════════════════════════════════
# Google Chat (Webhook / OAuth for bot)
# ══════════════════════════════════════════════════════════════════════════════
GOOGLE_CHAT_PROJECT_NUMBER=           # GCP project number for Chat API
GOOGLE_CHAT_SERVICE_ACCOUNT=         # Service account email for Chat

# ══════════════════════════════════════════════════════════════════════════════
# CORS (comma-separated origins)
# ══════════════════════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ══════════════════════════════════════════════════════════════════════════════
# API Security
# ══════════════════════════════════════════════════════════════════════════════
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
